# Paste into Railway → your service → Variables (do not commit real secrets)
#
# CLI deploy from this machine (interactive login):
#   npm run railway:login
#
# If `railway link` fails with "Available options can not be empty", your workspace
# has no projects yet. Create one and link in one step:
#   npm run railway:init -- --name runway-hackathon -w "Murk's Projects"
#   (use your workspace name exactly; then deploy:)
#   npm run railway:deploy
#
# If you already have a project in the dashboard, link by id (no empty list):
#   npx railway list --json
#   npm run railway:link -- -p <project-id> [-s <service-name>]
#
# Non-interactive (CI / agent): create a token in Railway → Account → Tokens,
# then export RAILWAY_TOKEN=... before `npm run railway:deploy`.

# App URL (use your Railway public URL, https, no trailing slash)
NEXTAUTH_URL=https://YOUR-SERVICE.up.railway.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

RUNWAY_API_KEY=
OPENAI_API_KEY=

# Claude via Bedrock (matches local .env pattern)
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# Optional model override
# ANTHROPIC_BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

# After you add a Railway volume, set mount path here so DB + uploads survive redeploys
# PERSISTENT_DATA_ROOT=/data
