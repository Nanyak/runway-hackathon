# Paste into Railway → your service → Variables (do not commit real secrets)
#
# Deploy: use the Railway dashboard (GitHub integration) or install the CLI when needed:
#   npm i -g @railway/cli   # then: railway login, railway link, railway up

# App URL (use your Railway public URL, https, no trailing slash)
NEXTAUTH_URL=https://YOUR-SERVICE.up.railway.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

RUNWAY_API_KEY=
OPENAI_API_KEY=

# Claude via Bedrock (matches local .env pattern)
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# Optional model override
# ANTHROPIC_BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

# ── Persistence (pick ONE option or sessions won't survive restarts) ──────────
#
# Option A: Railway volume  (cheapest, no egress fees)
#   1. Railway dashboard → your service → Volumes → Add Volume, mount at /data
#   2. Uncomment the line below:
PERSISTENT_DATA_ROOT=/data
#
# Option B: S3-compatible object storage (Cloudflare R2, AWS S3, etc.)
#   Sessions are mirrored to the bucket automatically — no volume needed.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET=
# AWS_ENDPOINT_URL=          # omit for real AWS S3; set for R2/MinIO
# AWS_REGION=auto            # use "auto" for R2, your AWS region for S3
